# Exam Platform — environment variables.
# Copy to `.env` and fill in. `.env` is git-ignored and Docker-ignored.
#
# Two profiles in one file:
#   * Bare-metal local dev (uvicorn on host, postgres/redis on host) — use
#     "localhost" hostnames.
#   * docker compose — `docker-compose.yml` overrides DATABASE_URL/REDIS_URL
#     with the in-network hostnames `db` and `redis`. The values below are
#     fine to leave as-is for compose; compose just ignores them.

# ── Runtime ────────────────────────────────────────────────────────────────
ENV=local                     # local | dev | staging | prod | test
DEBUG=true                    # verbose error pages — set false in prod
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR

# ── HTTP server ────────────────────────────────────────────────────────────
APP_HOST=127.0.0.1            # use 0.0.0.0 inside containers
APP_PORT=8000                 # host port mapped by docker-compose

# ── Postgres ───────────────────────────────────────────────────────────────
# SQLAlchemy URL. For docker compose, leave the localhost host here — compose
# substitutes `db` automatically. PG14 cluster, separate db + role.
DATABASE_URL=postgresql+psycopg://exam_platform_user:exam_platform_pw@localhost:5432/exam_platform_db
POSTGRES_USER=exam_platform_user
POSTGRES_PASSWORD=exam_platform_pw
POSTGRES_DB=exam_platform_db
DB_PORT=5432

# ── Redis (rate limiting, sessions, RQ queues) ────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# ── Mailhog (compose only — local SMTP capture for dev) ───────────────────
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# ── Sessions / security ────────────────────────────────────────────────────
# CRITICAL: rotate before any non-local deployment. Min 32 random bytes.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-before-prod
SESSION_COOKIE_NAME=exam_session
SESSION_TTL_DAYS=7
ADMIN_REPROMPT_HOURS=24

# ── First-admin bootstrap (used by scripts/create_admin) ──────────────────
# Read by the create_admin CLI; not read by the running app.
EXAM_ADMIN_PW=change-me-before-creating-admin

# ── Observability ─────────────────────────────────────────────────────────
# Empty/unset → Sentry disabled. Production: paste your DSN.
SENTRY_DSN=

# ── Imports / uploads (Phase 05) ──────────────────────────────────────────
# UPLOADS_DIR is mounted as a named volume in docker-compose; override only
# if you need a custom path on bare metal.
# UPLOADS_DIR=/srv/exam-platform/uploads
# IMPORT_MAX_BYTES=26214400
# IMPORT_MAX_ROWS=5000
