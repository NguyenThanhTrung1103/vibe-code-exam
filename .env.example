# Exam Platform — local environment variables
# Copy to `.env` and fill in. `.env` is git-ignored.

# Runtime ----------------------------------------------------------------------
ENV=local
DEBUG=true
LOG_LEVEL=INFO

# HTTP server ------------------------------------------------------------------
APP_HOST=127.0.0.1
APP_PORT=8000

# Postgres ---------------------------------------------------------------------
# Local SQLAlchemy URL. In docker-compose the host is `db`; outside compose use
# `localhost`. PG14 cluster, separate db + role per Phase 02.
DATABASE_URL=postgresql+psycopg://exam_platform_user:exam_platform_pw@localhost:5432/exam_platform_db
POSTGRES_USER=exam_platform_user
POSTGRES_PASSWORD=exam_platform_pw
POSTGRES_DB=exam_platform_db
DB_PORT=5432

# Redis ------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# Sessions / security ----------------------------------------------------------
SECRET_KEY=change-me-before-prod
SESSION_COOKIE_NAME=exam_session
SESSION_TTL_DAYS=7
ADMIN_REPROMPT_HOURS=24

# Observability ----------------------------------------------------------------
# Leave blank to disable Sentry locally.
SENTRY_DSN=
