/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
dist/
bin/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# package manager
package-lock.json
yarn.lock
pnpm-lock.yaml

# semantic-release
.nyc_output

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# flutter
.dart_tool
build
GoogleService-Info.plist

repomix-output.xml
.serena/cache
# plans/ is now tracked (NewPRD, phase plans, red-team + completion reports).
# Re-add a narrow rule here if local-only scratch dirs appear under plans/.
screenshots/*
docs/screenshots/*
logs.txt
test-ck
__pycache__

# CK meta commands
prompt.md
ck.md

# Claude Code project config — tiered: track team-shared parts, ignore vendored/runtime.
# Default-ignore everything under .claude/, then re-include the team-shared subset.
.claude/*
!.claude/CLAUDE.md
!.claude/agents/
!.claude/hooks/
!.claude/rules/
!.claude/schemas/
!.claude/scripts/
!.claude/settings.json
!.claude/statusline.cjs

# Heavy / regenerable / runtime under .claude/ — always ignore even if re-included above
.claude/skills/
.claude/metadata.json
.claude/agent-memory/
.claude/session-state/
.claude/command-archive/
.claude/output-styles/
.claude/hooks/.logs/
.claude/settings.bak.json
.claude/settings.local.json

# Gemini CLI settings (symlink to staged .claude/.mcp.json)
.gemini/settings.json
# External repos for study/reference
external/

# Git worktrees (local development only)
worktrees/

# Vendored OpenCode skills/agents library (regenerable; ~16 MB, ~1k files)
.opencode/
# Generated OpenCode backup from scripts/generate-opencode.py --force
.opencode.backup/

# ---------- Python (Phase 01 scaffolding) ----------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
.venv/
venv/
env/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# Build artifacts
build/
dist/

# Logs
*.log
logs/

# User-uploaded private content (defensive — nothing here on this host yet)
uploads/
app/uploads/

# CK release manifest (regenerated by ClaudeKit; not project source)
release-manifest.json
